# Desarrollo local (PostgreSQL)
DB_NAME=db_escuela
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Producción Render (Internal Database URL)
# DATABASE_URL=postgresql://usuario:password@host/educontrol
# DATABASE_SSL=False

SECRET_KEY=genera-una-clave-segura-y-larga
DEBUG=True

# Hosts permitidos (puedes usar URL completa; Django normaliza el hostname)
ALLOWED_HOSTS=127.0.0.1,localhost,192.168.18.13,https://educontrol-nskr.onrender.com/

# Orígenes CORS del frontend (sin ruta, sin barra final)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://edu-control-azure.vercel.app

# Interfaz visual de la API (Browsable API). True en local, False en producción.
API_BROWSABLE=True
